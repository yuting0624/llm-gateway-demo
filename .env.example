# Copy to .env and fill in. Do NOT commit .env (it is gitignored).
#
# Used by deploy.sh and sync-spend-to-bq.sh.

# === Required for deploy.sh ===
PROJECT_ID=your-gcp-project-id

# === Optional (defaults shown) ===
REGION=asia-northeast1
SERVICE_NAME=litellm-proxy
BQ_DATASET=llm_gateway

# === Set after deployment ===
# The Cloud Run URL printed by deploy.sh
PROXY_URL=https://litellm-proxy-xxxxx.asia-northeast1.run.app

# The master key printed by deploy.sh (or pre-set before running deploy.sh
# to use a known value).
LITELLM_MASTER_KEY=replace-with-deploy-output
